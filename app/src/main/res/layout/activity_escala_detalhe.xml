<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".views.EscalaDetalheActivity">

    <!-- HEADER -->
    <include
        android:id="@+id/header_layout"
        layout="@layout/header"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- CONTEÚDO -->
    <ScrollView
        android:id="@+id/scroll_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:padding="16dp"
        android:background="#F5F6FA"
        app:layout_constraintTop_toBottomOf="@id/header_layout"
        app:layout_constraintBottom_toTopOf="@id/footer_layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- CARD PRINCIPAL -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:elevation="4dp">

                <!-- TÍTULO -->
                <TextView
                    android:id="@+id/tvData"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Escala - 15/06/2025"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingBottom="16dp"/>

                <!-- NOME -->
                <TextView
                    android:id="@+id/tvNome"
                    style="@style/EscalaItemStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:drawableStart="@drawable/ic_ministerio"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <!-- HORA -->
                <TextView
                    android:id="@+id/tvHora"
                    style="@style/EscalaItemStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:drawableStart="@drawable/ic_clock"
                    android:drawablePadding="8dp"
                    android:layout_marginBottom="16dp"/>

                <!-- MÚSICOS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_background"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Músicos"
                        android:textStyle="bold"
                        android:textSize="16sp"/>

                    <TextView android:id="@+id/tvBaterista" style="@style/EscalaItemStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <TextView android:id="@+id/tvBaixista" style="@style/EscalaItemStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <TextView android:id="@+id/tvGuitarrista" style="@style/EscalaItemStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <TextView android:id="@+id/tvSaxofonista" style="@style/EscalaItemStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <TextView android:id="@+id/tvTecladista" style="@style/EscalaItemStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <TextView android:id="@+id/tvViolonista" style="@style/EscalaItemStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- VOCAIS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_background"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Vocais"
                        android:textStyle="bold"
                        android:textSize="16sp"/>

                    <TextView android:id="@+id/tvVocalista1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <TextView android:id="@+id/tvVocalista2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <TextView android:id="@+id/tvVocalista3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <TextView android:id="@+id/tvVocalista4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- CARD MÚSICAS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_background"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tvMusicas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:drawableStart="@drawable/ic_music"
                        android:drawablePadding="8dp"
                        android:text="Músicas"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvMusicas"
                        android:layout_width="match_parent"
                        android:layout_height="300dp"
                        android:nestedScrollingEnabled="false"/>

                    <TextView
                        android:id="@+id/tvMusicasVazia"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Nenhuma música associada a esta escala."
                        android:textSize="16sp"
                        android:gravity="center"
                        android:visibility="gone"/>
                </LinearLayout>

                <!-- PLAYER -->
                <ProgressBar
                    android:id="@+id/progressLoading"
                    style="@android:style/Widget.DeviceDefault.Light.ProgressBar.Large"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone"/>

                <SeekBar
                    android:id="@+id/seekBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/btnPrev"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_media_previous"
                        android:background="@android:color/transparent"/>

                    <ImageButton
                        android:id="@+id/btnPlayPause"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@android:drawable/ic_media_play"
                        android:background="@android:color/transparent"/>

                    <ImageButton
                        android:id="@+id/btnNext"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_media_next"
                        android:background="@android:color/transparent"/>
                </LinearLayout>

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tvCurrentTime"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="0:00"/>

                    <TextView
                        android:id="@+id/tvTotalTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0:00"/>
                </LinearLayout>

                <!-- OBS -->
                <TextView
                    android:id="@+id/tvObservacoes"
                    style="@style/EscalaItemStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"/>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- FOOTER -->
    <include
        android:id="@+id/footer_layout"
        layout="@layout/footer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>